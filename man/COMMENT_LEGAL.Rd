\name{COMMENT_LEGAL}
\alias{COMMENT_LEGAL}
\title{Valida se um valor está entre os valores permitidos}
\usage{COMMENT_LEGAL(value, legal_values)}
\arguments{
  \item{value}{Valor a ser verificado.}
  \item{legal_values}{Vetor de valores válidos.}
}
\value{Lógico: `TRUE` se o valor for permitido.}
