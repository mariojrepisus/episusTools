\name{p_valor_z}
\alias{p_valor_z}
\title{Teste Z para proporção contra 0.5}
\description{Calcula o p-valor bilateral de um teste Z comparando uma proporção observada contra a hipótese nula de `prop`.}
\usage{p_valor_z(x, n, prop = 0.5)}
\arguments{
  \item{x}{Número de sucessos.}
  \item{n}{Total de tentativas.}
  \item{prop}{Proporção hipotética (padrão: 0.5).}
}
\value{P-valor bilateral (numérico).}
